<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
  <div class="col-8 offset-2">
    <br> <br>
    <h3>Create a New Listing</h3>
    <form 
    method ="POST" 
    action="/listings"  
    class="needs-validation" 
    novalidate 
    enctype="multipart/form-data"
    >
        <div class="mb-3">
            <lable for="title" class="form-label">Title</lable>
            <input name="listing[title]"
             placeholder="Add a catchy title" 
             type="text"
             class="form-control"
             required/>
             <div class="valid-feedback">Title looks goods!</div>
        </div>
        
        <div class="mb-3" >
             <lable  for="description" class="form-label">Description</lable>
             <textarea 
             name="listing[description]" 
             class="form-control"
             required>
            </textarea>
            <div class="invalid-description">Please enter a short description</div>
        </div>

        <div class="mb-3">
            <lable for="image" class="form-label">Upload image</lable>
            <input 
            name="listing[image]"  
            type="file"
            class="form-control">
            </div>    
    
        <div class="row">
            <div class="mb-3 col-md-4">
            <lable for="price" class="form-label">Price</lable>
            <input 
            name="listing[price]" 
            placeholder="4000"  
            type="number"
            class="form-control"
            required>
            <div class="invalid-feedback">Price should be valid</div>
            </div>
    
            <div class="mb-3 col-md-8">
            <lable for="country" class="form-label">Country</lable>
            <input
            name="listing[country]" 
            placeholder="India"  
            type="text"
            class="form-control"
            required>
            <div class="invalid-feedback">Country should be valid</div>
            </div> 
        </div>


        <div class="mb-3">
            <label for="location" class="form-label">location</label>
            <input 
            name="listing[location]" 
            placeholder="Delhi"  
            type="text"
            class="form-control"
            required>
            <div class="invalid-feedback">Location should be valid</div>
        </div>

        <div class="mb-3">
    <label class="form-label">Category</label>
    <select name="listing[category]" class="form-control" required>
      <option value="trending">All Listings</option>
      <option value="trending">Trending</option>
      <option value="rooms">Rooms</option>
      <option value="iconic-cities">Iconic Cities</option>
      <option value="mountains">Mountains</option>
      <option value="castles">Castles</option>
      <option value="amazing-pools">Amazing Pools</option>
      <option value="farms">Farms</option>
      <option value="camping">Camping</option>
      <option value="arctic">Arctic</option>
    </select>
  </div>
    
    <br> <br>
    <button class="btn btn-dark add-btn mb-3">Add</button>
    <br> <br>
    </form>
  </div> 
</div>


    